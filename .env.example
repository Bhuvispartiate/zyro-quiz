# Pusher credentials — get these from https://pusher.com (free account)
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=ap2

# Upstash Redis — set automatically when you link Upstash Redis in Vercel dashboard
# For local testing, get these from https://console.upstash.com
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
